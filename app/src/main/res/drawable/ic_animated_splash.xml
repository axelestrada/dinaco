                    android:name="path_1"
                    android:pathData="M 48.75 77.5 C 51.25 80.416 58.375 84.5 66.875 77.5 M 56.25 56.25 C 56.25 51.25 63.75 51.25 63.75 56.25 M 71.25 56.25 C 71.25 51.875 78.75 51.25 78.75 56.875"
