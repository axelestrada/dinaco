                android:translateX="3.75">
                <path
                    android:name="path"
                    android:pathData="M 74.375 40 C 87.838 40 98.125 55.157 98.125 70 C 98.125 84.612 86.942 93.472 73.75 93.744 C 73.659 93.746 73.567 93.746 73.476 93.748 C 73.36 93.749 73.243 93.75 73.125 93.75 L 72.596 93.744 L 65 93.745 C 64.793 93.749 64.584 93.75 64.375 93.75 C 48.843 93.75 36.25 85.075 36.25 74.375 C 36.25 67.209 41.896 60.953 50.291 57.6 C 53.843 47.328 61.875 40 74.375 40 Z"
